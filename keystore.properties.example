# Copy this file to keystore.properties in the project root (do not commit keystore.properties).
# Generate an upload keystore for Play App Signing, e.g.:
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Bump versionCode in app/build.gradle.kts for every Play upload. Build AAB:
#   ./gradlew :app:bundleRelease

storeFile=upload-keystore.jks
storePassword=
keyAlias=upload
keyPassword=
